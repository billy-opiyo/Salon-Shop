{
	"functions": {
		"source": "functions",
		"runtime": "nodejs22"
	},
	"firestore": {
		"rules": "firestore.rules"
	},
	"hosting": {
		"target": "main-site",
		"public": "public",
		"ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
	},
	"emulators": {
		"auth": {
			"port": 9099
		},
		"functions": {
			"port": 5001
		},
		"firestore": {
			"port": 18080
		},
		"hosting": {
			"port": 5000
		},
		"ui": {
			"enabled": true,
			"port": 4000
		},
		"singleProjectMode": true
	}
}
